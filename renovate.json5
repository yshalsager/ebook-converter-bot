{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':rebaseStalePrs',
    'group:allNonMajor',
    'docker:pinDigests',
    'helpers:pinGitHubActionDigests',
  ],
  timezone: 'Africa/Cairo',
  labels: [
    'dependencies',
  ],
  schedule: [
    'before 5am on saturday',
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
    schedule: [
      'before 5am on saturday',
    ],
  },
  packageRules: [
    {
      matchUpdateTypes: [
        'minor',
        'patch',
        'pin',
        'digest',
      ],
      automerge: true,
      minimumReleaseAge: '3 days',
    },
    {
      description: 'Handle date-based tags for calibre-with-kfx image',
      matchManagers: [
        'dockerfile',
      ],
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'ghcr.io/yshalsager/calibre-with-kfx',
      ],
      versioning: 'regex:^(?<major>\\d{4})(?<minor>\\d{2})(?<patch>\\d{2})-(?<build>\\d{4})$',
    },
  ],
}
